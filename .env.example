# ============================================================================
#  Exemplo de variáveis de ambiente. Copie para .env e ajuste se necessário.
#    cp .env.example .env
# ============================================================================

# --- Aplicação Laravel ---
APP_NAME="grpc-hybrid-chat"
APP_ENV=local
APP_DEBUG=true
APP_KEY=
APP_URL=http://localhost

# --- Conexão com o microsserviço gRPC (Node.js) ---
# Dentro da rede Docker o host é o nome do serviço: node-server.
GRPC_SERVER_HOST=node-server
GRPC_SERVER_PORT=50051

# --- Sessão (em arquivo; sem banco neste laboratório) ---
SESSION_DRIVER=file
SESSION_LIFETIME=120

# --- Logs ---
LOG_CHANNEL=stderr
LOG_LEVEL=debug
